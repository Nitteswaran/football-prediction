# Copy to .env (never commit .env). In production, set these as platform
# secrets / environment variables instead of shipping a file.

# Stripe secret key — sk_test_... locally, sk_live_... in production only.
STRIPE_SECRET_KEY=

# Price id of the one-time insights unlock (defaults to the live $5 price).
#PITCHSENSE_STRIPE_PRICE=price_1ThQREGpqZjDsnwvYaKgzRvH

# Public origin of the deployed site, used for Stripe redirect URLs.
# Required in production behind a proxy/CDN; e.g. https://pitchsense.app
PUBLIC_BASE_URL=

# Comma-separated extra origins allowed via CORS. Leave empty when the
# frontend is served by this app (same origin needs no CORS).
PITCHSENSE_CORS_ORIGINS=

# Optional owner/comp code. Enter this in the site's "Already paid? Enter your
# code" box to unlock for free (no Stripe charge, ignores the device cap).
# Treat it like a password; leave unset to disable. e.g. a long random string.
PITCHSENSE_OWNER_CODE=
